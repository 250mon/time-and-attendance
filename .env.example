DATABASE_URL=postgresql+psycopg://clinic_time_user:change_me@postgres:5432/clinic_time

BACKEND_SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false

FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost/api
NEXT_PUBLIC_BACKEND_URL=http://localhost/api

# Host port mappings (docker-compose.yml, local dev only)
FRONTEND_PORT=3000
BACKEND_PORT=8000

CLINIC_TIMEZONE=Asia/Seoul

SEED_CLINIC_NAME=Demo Clinic
SEED_ADMIN_EMAIL=admin@clinic.example
