POSTGRES_DB=clinic_time
POSTGRES_USER=clinic_time_user
POSTGRES_PASSWORD=change_me
# Set this to point at any reachable PostgreSQL instance (managed/external DB, different
# host, etc.) - it takes precedence over POSTGRES_USER/PASSWORD/DB below. Leave it matching
# the bundled `postgres` service (as below) to use the one Docker Compose starts for you.
DATABASE_URL=postgresql+psycopg://clinic_time_user:change_me@postgres:5432/clinic_time

BACKEND_SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true

# Used by Caddy for TLS + routing. Set DOMAIN to your real domain in production.
DOMAIN=yourdomain.com
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://yourdomain.com/api
NEXT_PUBLIC_BACKEND_URL=https://yourdomain.com/api  # browser-facing, routed by Caddy to /api/*

# Host port mappings (docker-compose.yml)
HTTP_PORT=80
HTTPS_PORT=443

CLINIC_TIMEZONE=Asia/Seoul

SEED_CLINIC_NAME=Demo Clinic
SEED_ADMIN_EMAIL=admin@clinic.example
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Clinic Admin

LOG_LEVEL=INFO
